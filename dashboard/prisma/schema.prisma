generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Bug Bounty Programs ──

model Program {
  id            String   @id @default(cuid())
  platform      Platform
  name          String
  slug          String
  url           String
  intigritiId   String?
  scope         Json     @default("[]")
  compliance    Json     @default("{}")
  maxBounty     Float?
  minBounty     Float?
  currency      String   @default("EUR")
  industry      String?
  programType   String?
  confidentiality String?
  managed       Boolean  @default(false)
  active        Boolean  @default(true)
  syncedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  scans         Scan[]

  @@unique([platform, slug])
  @@index([platform])
  @@index([intigritiId])
}

enum Platform {
  INTIGRITI
  HACKERONE
  YESWEHACK
  MANUAL
}

// ── Scans ──

model Scan {
  id          String     @id @default(cuid())
  target      String
  status      ScanStatus @default(QUEUED)
  config      Json       @default("{}")
  startedAt   DateTime?
  finishedAt  DateTime?
  duration    Int?
  error       String?
  phases      Json       @default("[]")
  stats       Json       @default("{}")
  programId   String?
  program     Program?   @relation(fields: [programId], references: [id])
  findings       Finding[]
  crawlEndpoints CrawlEndpoint[]
  checkpoint     ScanCheckpoint?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([status])
  @@index([target])
}

enum ScanStatus {
  QUEUED
  RUNNING
  COMPLETE
  ERROR
  CANCELLED
}

// ── Findings ──

model Finding {
  id           String          @id @default(cuid())
  scanId       String
  scan         Scan            @relation(fields: [scanId], references: [id], onDelete: Cascade)
  module       String
  severity     Severity
  confidence   Float           @default(0.5)
  title        String
  description  String          @db.Text
  url          String?
  evidence     Json            @default("{}")
  remediation  String?         @db.Text
  status       FindingStatus   @default(NEW)
  falsePositive Boolean        @default(false)
  cweId        String?
  cvssScore    Float?
  notes        String?         @db.Text
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([scanId, module, title, url])
  @@index([scanId])
  @@index([severity])
  @@index([status])
  @@index([module])
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum FindingStatus {
  NEW
  CONFIRMED
  FALSE_POSITIVE
  FIXED
  ACCEPTED
  REPORTED
}

// ── Crawl Endpoints (persisted during recon) ──

model CrawlEndpoint {
  id        String   @id @default(cuid())
  scanId    String
  scan      Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  url       String
  method    String   @default("GET")
  params    Json     @default("[]")
  source    String?  // e.g. "sitemap", "crawler", "js_mining"
  createdAt DateTime @default(now())

  @@index([scanId])
  @@unique([scanId, url, method])
}

// ── Scan Checkpoints (resume support) ──

model ScanCheckpoint {
  id             String   @id @default(cuid())
  scanId         String   @unique
  scan           Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  lastModule     Int      @default(0) // 0-8, index of last completed module
  lastModuleName String   @default("")
  endpointsTotal Int      @default(0)
  findingsCount  Int      @default(0)
  stats          Json     @default("{}")
  phase          String   @default("recon")
  progress       Float    @default(0)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

// ── Reports ──

model Report {
  id          String       @id @default(cuid())
  title       String
  target      String
  platform    Platform?
  content     Json         @default("{}")
  format      ReportFormat @default(MARKDOWN)
  submitted   Boolean      @default(false)
  submittedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum ReportFormat {
  MARKDOWN
  PDF
  HTML
}

// ── Stats Tracking ──

model BountyRecord {
  id          String   @id @default(cuid())
  platform    Platform
  program     String
  amount      Float
  currency    String   @default("EUR")
  status      String
  reportTitle String?
  awardedAt   DateTime
  createdAt   DateTime @default(now())
}

// ── Settings (singleton config) ──

model IntigritiConfig {
  id            String   @id @default("singleton")
  token         String?
  autoSync      Boolean  @default(true)
  syncInterval  Int      @default(15)
  updatedAt     DateTime @updatedAt
}
